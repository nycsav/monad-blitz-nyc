# MonadSwarm agents/.env (copy to .env)

# Monad Testnet
MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz

# Claude (agent strategy brain). Get a key at console.anthropic.com
ANTHROPIC_API_KEY=

# Deployed contract addresses (filled in after `contracts/deploy.sh`)
RISK_ROUTER=
SIGNAL_ANCHOR=
AGENT_REGISTRY=

# Agent signing keys (same throwaway testnet keys generated for contracts/.env)
AGENT1_PRIVATE_KEY=
AGENT2_PRIVATE_KEY=
AGENT3_PRIVATE_KEY=

# On-chain agent IDs (assigned by AgentRegistry.registerAgent, set after `npm run register`)
AGENT1_ID=1
AGENT2_ID=2
AGENT3_ID=3
