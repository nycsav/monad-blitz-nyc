# MonadSwarm — contracts/.env  (copy to .env, never commit the real one)

# Monad Testnet
MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz
MONAD_FALLBACK_RPC=https://rpc.ankr.com/monad_testnet
CHAIN_ID=10143

# Deployer key (fund this address from https://faucet.monad.xyz)
PRIVATE_KEY=0x...

# Optional: override the vault trading asset (defaults to canonical USDC)
# VAULT_ASSET=0x534b2f3A21130d7a60830c2Df862319e593943A3

# Agent signing keys (3 parallel strategies) — throwaway testnet keys
AGENT1_PRIVATE_KEY=0x...
AGENT2_PRIVATE_KEY=0x...
AGENT3_PRIVATE_KEY=0x...

# Filled in after deploy
AGENT_REGISTRY=
SIGNAL_ANCHOR=
SIGNAL_VAULT=
RISK_ROUTER=

# Optional Monadscan verification key
MONADSCAN_API_KEY=
